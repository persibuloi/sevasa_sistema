# Copiar a .env y llenar con los valores del proyecto Supabase (NUEVO, separado del BI)
# Cadena de conexión: Supabase → botón "Connect" → Connection string → Transaction pooler
# OJO: caracteres especiales de la contraseña van URL-encoded (% → %25, @ → %40)
DATABASE_URL=postgresql://postgres.XXXX:CLAVE@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Supabase Auth (el backend valida los tokens de sesión contra /auth/v1/user)
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

PUERTO=3001
