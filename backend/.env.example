# Copiar a .env y llenar con los valores del proyecto Supabase (NUEVO, separado del BI)
# Cadena de conexión: Supabase → Settings → Database → Connection string (URI, con pooler)
DATABASE_URL=postgresql://postgres.XXXX:CLAVE@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase Auth (para validar los JWT de los usuarios)
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_JWT_SECRET=

PUERTO=3001